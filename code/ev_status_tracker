#define BLYNK_PRINT Serial
#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <OneWire.h>
#include <DallasTemperature.h>

char auth[] = "BLYNK_AUTH_TOKEN";
char ssid[] = "WIFI_NAME";
char pass[] = "WIFI_PASSWORD";

#define VOLTAGE_PIN 34
#define VIBRATION_PIN 27
#define FAN_PIN 26
#define LED_PIN 25

#define ONE_WIRE_BUS 4
OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);

float voltage = 0.0;
float soc = 0.0;
float temperature = 0.0;
int vibrationState = 0;

float voltageDividerRatio = 5.7;

float TEMP_THRESHOLD = 40.0;
float SOC_THRESHOLD = 20.0;

BlynkTimer timer;

float calculateSoC(float voltage) {
  float minV = 9.0;
  float maxV = 12.6;
  float soc = ((voltage - minV) / (maxV - minV)) * 100.0;
  if (soc > 100) soc = 100;
  if (soc < 0) soc = 0;
  return soc;
}

void readSensors() {
  int raw = analogRead(VOLTAGE_PIN);
  voltage = (raw / 4095.0) * 3.3 * voltageDividerRatio;
  soc = calculateSoC(voltage);

  sensors.requestTemperatures();
  temperature = sensors.getTempCByIndex(0);

  vibrationState = digitalRead(VIBRATION_PIN);

  if (soc < SOC_THRESHOLD) {
    digitalWrite(LED_PIN, HIGH);
  } else {
    digitalWrite(LED_PIN, LOW);
  }

  if (temperature > TEMP_THRESHOLD) {
    digitalWrite(FAN_PIN, HIGH);
    digitalWrite(LED_PIN, HIGH);
  } else {
    digitalWrite(FAN_PIN, LOW);
  }

  Serial.println("------ EV STATUS ------");
  Serial.print("Voltage: "); Serial.println(voltage);
  Serial.print("SoC: "); Serial.println(soc);
  Serial.print("Temperature: "); Serial.println(temperature);
  Serial.print("Vibration: "); Serial.println(vibrationState);
  Serial.println("----------------------");

  Blynk.virtualWrite(V0, voltage);
  Blynk.virtualWrite(V1, soc);
  Blynk.virtualWrite(V2, temperature);
  Blynk.virtualWrite(V3, vibrationState);
}

void setup() {
  Serial.begin(115200);

  pinMode(VIBRATION_PIN, INPUT);
  pinMode(FAN_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);

  sensors.begin();

  Blynk.begin(auth, ssid, pass);

  timer.setInterval(2000L, readSensors);
}

void loop() {
  Blynk.run();
  timer.run();
}
